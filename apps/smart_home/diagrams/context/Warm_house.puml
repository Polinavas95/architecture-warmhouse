@startuml
!include <C4/C4_Context>
!include <C4/C4_Container>

LAYOUT_WITH_LEGEND()

title Экосистема умных домов "Тёплый дом" (Диаграмма контекста)


' === Внешние системы ===
System_Ext(sms, "SMS-шлюз", "Отправка уведомлений и кодов подтверждения")
System_Ext(phone_system, "Телефонная станция", "Осуществление звонков в поддержку компании")
System_Ext(payment, "Платежная система", "Обработка платежей за заказы")
System_Ext(messenger, "Мессенджер", "Внутренний канал для чата с поддержкой")
System_Ext(partners, "API партнеров", "Предоставление рекламных материалов и новостей")

' === Внутренние системы компании ===
System_Ext(gitlab, "GitLab/Bitbucket", "Хранение кода, CI/CD, управление задачами")
System_Ext(monitoring, "Система мониторинга", "Grafana/Prometheus/Kibana")
System_Ext(crm, "CRM система", "Управление клиентами и инцидентами")
System_Ext(analytics, "Аналитическая платформа", "Анализ логов пользователей, метрики")

' === Пользователи ===
Person(owner, "Владелец дома", "Житель дома, который может: покупать наборы устройств; управлять гаджетами умного дома")
Person(admin, "Системный администратор", "Сотрудник компании, отвечающий за мониторинг и поддержку системы; диагностику и регистрацию приборов в системе")
Person(developer, "Разработчик", "Сотрудник компании, отвечающий за кодовую базу (рефакторинг/вывод фичей/разделение на микросервисы)")
Person(QA, "Тестировщик", "Сотрудник компании, отвечающий за тестирование приложения")
Person(customer_service, "Обслуживание клиентов", "Сотрудник компании, предоставляющий поддрежку пользователей")
Person(marketing_person, "Продажа и маркетинг", "Сотрудник компании, занимающийся продвижением новых модульных комплектов")

' === система Теплый дом ===
System(smart_home, "Экосистема Тёплый дом", "Платформа для удаленного управления отоплением, светом, воротами, продажей комплектов умного дома")

' === Устройства ===
System_Ext(heater, "Устройства отопления", "Датчики-термостаты, котлы (на территории пользователя)")
System_Ext(lamps, "Устройства освещения", "Умные лампы (на территории пользователя)")
System_Ext(gates, "Приводы ворот", "Автоматические контроллеры (на территории пользователя)")

' === Связи (взаимодействия) ===
Rel(owner, smart_home, "Заказывает комплекты, управляет устройствами, смотрит видеоинструкции", "Интернет (HTTPS)/мобильное приложение")
Rel(admin, monitoring, "Проводит диагностику, подключает новых клиентов", "внутренний канал (Cisco)")
Rel(admin, monitoring, "Мониторит логи и метрики", "HTTPS")
Rel(developer, gitlab, "Разрабатывает кодовую базу, улучшает производительность, масштабирует приложение", "Интернет (HTTPS)")
Rel(QA, gitlab, "Тестирует новый функционал, проводит нагрузочное тестирование, составляет отчеты о тестировании", "Интернет (HTTPS), Postman/Insomnia")
Rel(QA, smart_home, "Тестирует через тестовые аккаунты", "HTTPS/API, Postman/Insomnia")
Rel(customer_service, crm, "Ведет историю обращений", "Интернет (HTTPS)")
Rel(customer_service, messenger, "Общается с клиентами", "Webhook/API")
Rel(marketing_person, analytics, "Изучает аналитику", "Интернет (HTTPS)")
Rel(analytics, smart_home, "Собирает данные о поведении", "ETL/API")

' Взаимодействие системы с внешними сервисами
Rel(smart_home, sms, "Отправляет SMS с кодами и уведомлениями", "HTTPS")
Rel(smart_home, phone_system, "Инициирует звонок в поддержку", "SIP/Телефонная сеть")
Rel(smart_home, payment, "Отправляет запросы на списание/возврат средств", "HTTPS")
Rel(smart_home, messenger, "Отправляет/получает сообщения в чат поддержки", "Webhook/API")
Rel(smart_home, partners, "Запрашивает рекламные материалы и новости", "HTTPS/REST")

' Взаимодействие с физическими устройствами
Rel(smart_home, heater, "Отправляет команды (вкл/выкл, установка температуры), получает телеметрию", "Интернет / MQTT")
Rel(smart_home, lamps, "Отправляет команды (вкл/выкл), получает данные о потреблении", "Интернет / MQTT")
Rel(smart_home, gates, "Отправляет команды (открыть/закрыть), получает статус", "Интернет / MQTT")

@enduml